{
  "name": "practicode",
  "version": "0.1.20",
  "description": "Offline-first programming language lessons and coding practice in a Rust terminal UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baba9811/practicode.git"
  },
  "homepage": "https://github.com/baba9811/practicode#readme",
  "bugs": {
    "url": "https://github.com/baba9811/practicode/issues"
  },
  "bin": {
    "practicode": "bin/practicode.js"
  },
  "scripts": {
    "start": "node bin/practicode.js",
    "build": "cargo build --release --locked",
    "smoke": "node bin/practicode.js --smoke",
    "test:launcher": "node --test tests/launcher.test.js"
  },
  "files": [
    "assets/",
    "bin/",
    "docs/",
    "!docs/superpowers/",
    "src/",
    "Cargo.lock",
    "Cargo.toml",
    "Dockerfile",
    ".dockerignore",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_LICENSES.md"
  ],
  "keywords": [
    "algorithms",
    "coding-practice",
    "learning",
    "programming-languages",
    "ratatui",
    "rust",
    "tui"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
